# Karbon interview — runtime config template (KARBON_ prefix, pydantic-settings).
# Copy to .env and tweak as needed:  cp .env.example .env

# --- LLM (local Ollama; no API key needed) ---
KARBON_LLM_PROVIDER=ollama
KARBON_LLM_MODEL=qwen3:14b
KARBON_LLM_BASE_URL=http://localhost:11434
# KARBON_LLM_TIMEOUT_S=30.0
# KARBON_LLM_MAX_RETRIES=3

# --- Embedding (RAG, scenario 8) ---
KARBON_EMBED_MODEL=bge-m3

# --- Resilience (circuit breaker) ---
# KARBON_BREAKER_FAIL_MAX=5
# KARBON_BREAKER_RESET_S=30.0

# --- Guardrails ---
# KARBON_ENABLE_INPUT_GUARDRAILS=true
# KARBON_ENABLE_PII_ANONYMIZE=true
# KARBON_INJECTION_RISK_THRESHOLD=0.5

# --- Hybrid decision / fail-closed ---
# KARBON_LOW_CONFIDENCE_THRESHOLD=0.5

# --- OpenRouter fallback (only if you choose to register a free key) ---
# KARBON_OPENROUTER_API_KEY=
# KARBON_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
